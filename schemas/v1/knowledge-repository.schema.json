{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Advance-Technologies-Foundation/clio-knowledge/schemas/v1/knowledge-repository.schema.json",
  "title": "Clio knowledge repository source",
  "description": "Human-readable source contract consumed directly from a trusted Git knowledge repository.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "contractVersion",
    "bundleSchemaVersion",
    "libraryId",
    "libraryVersion",
    "sequence",
    "compatibility",
    "requirements",
    "resources"
  ],
  "properties": {
    "$schema": {
      "const": "./schemas/v1/knowledge-repository.schema.json"
    },
    "contractVersion": {
      "const": "1.0.0"
    },
    "bundleSchemaVersion": {
      "const": "1.0.0"
    },
    "libraryId": {
      "$ref": "#/$defs/libraryId"
    },
    "libraryVersion": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "sequence": {
      "type": "integer",
      "minimum": 1
    },
    "compatibility": {
      "$ref": "#/$defs/compatibility"
    },
    "requirements": {
      "$ref": "#/$defs/requirements"
    },
    "resources": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1022,
      "items": {
        "$ref": "#/$defs/resource"
      }
    }
  },
  "$defs": {
    "stableId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$"
    },
    "libraryId": {
      "type": "string",
      "minLength": 3,
      "maxLength": 255,
      "pattern": "^[a-z0-9](?:[a-z0-9-]{0,62}[a-z0-9])?(?:\\.[a-z0-9](?:[a-z0-9-]{0,62}[a-z0-9])?)+$"
    },
    "versionRange": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min", "max"],
      "properties": {
        "min": {
          "type": "string",
          "minLength": 1
        },
        "max": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["clio", "mcpToolContract"],
      "properties": {
        "clio": {
          "$ref": "#/$defs/versionRange"
        },
        "mcpToolContract": {
          "$ref": "#/$defs/versionRange"
        }
      }
    },
    "requirements": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tools", "itemIds", "resourceUris"],
      "properties": {
        "tools": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "itemIds": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/stableId"
          }
        },
        "resourceUris": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^docs://knowledge/"
          }
        }
      }
    },
    "resource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "itemId",
        "topicId",
        "role",
        "uri",
        "sourcePath",
        "bundlePath",
        "mediaType"
      ],
      "properties": {
        "itemId": {
          "$ref": "#/$defs/stableId"
        },
        "topicId": {
          "$ref": "#/$defs/stableId"
        },
        "role": {
          "type": "string",
          "enum": ["guidance", "advisory", "capability", "reference-example"]
        },
        "uri": {
          "type": "string",
          "pattern": "^docs://knowledge/"
        },
        "legacyUris": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^docs://"
          }
        },
        "sourcePath": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512,
          "pattern": "^(guidance|catalog|advisories|capabilities)/(?!.*\\.\\.)[^\\\\]+$"
        },
        "bundlePath": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512,
          "pattern": "^resources/(?!.*\\.\\.)[^\\\\]+$"
        },
        "mediaType": {
          "type": "string",
          "pattern": "^text/"
        }
      }
    }
  }
}
