{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Advance-Technologies-Foundation/clio-knowledge/schemas/v1/knowledge-bundle.schema.json",
  "title": "Clio Knowledge Bundle Manifest v1",
  "description": "Signed, library-scoped knowledge generation for deterministic multi-source resolution.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contractVersion",
    "bundleSchemaVersion",
    "libraryId",
    "libraryVersion",
    "sequence",
    "source",
    "compatibility",
    "requirements",
    "digestAlg",
    "signature",
    "resources"
  ],
  "properties": {
    "contractVersion": { "const": "1.0.0" },
    "bundleSchemaVersion": { "const": "1.0.0" },
    "libraryId": { "$ref": "#/$defs/libraryId" },
    "libraryVersion": { "type": "string", "minLength": 1, "maxLength": 128 },
    "sequence": { "type": "integer", "minimum": 1 },
    "source": { "$ref": "#/$defs/source" },
    "compatibility": { "$ref": "#/$defs/compatibility" },
    "requirements": { "$ref": "#/$defs/requirements" },
    "digestAlg": { "const": "SHA-256" },
    "signature": { "$ref": "#/$defs/signature" },
    "resources": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/resource" }
    }
  },
  "$defs": {
    "libraryId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*(?:\\.[a-z][a-z0-9]*(?:-[a-z0-9]+)*)+$"
    },
    "stableId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$"
    },
    "role": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "commit"],
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "commit": { "type": "string", "pattern": "^(?:[0-9a-fA-F]{40}|[0-9a-fA-F]{64})$" }
      }
    },
    "versionRange": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min", "max"],
      "properties": {
        "min": { "type": "string", "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$" },
        "max": { "type": "string", "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$" }
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["clio", "mcpToolContract"],
      "properties": {
        "clio": { "$ref": "#/$defs/versionRange" },
        "mcpToolContract": { "$ref": "#/$defs/versionRange" }
      }
    },
    "requirements": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tools", "itemIds", "resourceUris"],
      "properties": {
        "tools": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "itemIds": {
          "type": "array",
          "items": { "$ref": "#/$defs/stableId" },
          "uniqueItems": true
        },
        "resourceUris": {
          "type": "array",
          "items": { "type": "string", "pattern": "^docs://knowledge/" },
          "uniqueItems": true
        }
      }
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "keyId"],
      "properties": {
        "algorithm": { "const": "ECDSA-P256-SHA256" },
        "keyId": { "type": "string", "minLength": 1 }
      }
    },
    "resource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["itemId", "topicId", "role", "uri", "path", "mediaType", "length", "digest"],
      "properties": {
        "itemId": { "$ref": "#/$defs/stableId" },
        "topicId": { "$ref": "#/$defs/stableId" },
        "role": { "$ref": "#/$defs/role" },
        "uri": { "type": "string", "pattern": "^docs://knowledge/" },
        "legacyUris": {
          "type": "array",
          "items": { "type": "string", "pattern": "^docs://" },
          "uniqueItems": true
        },
        "path": { "type": "string", "pattern": "^resources/(?!.*\\.\\.)[^\\\\]+$" },
        "mediaType": { "type": "string", "pattern": "^text/" },
        "length": { "type": "integer", "minimum": 0 },
        "digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    }
  }
}
