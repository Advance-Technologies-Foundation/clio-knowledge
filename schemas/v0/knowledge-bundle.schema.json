{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Advance-Technologies-Foundation/clio-knowledge/schemas/v0/knowledge-bundle.schema.json",
  "title": "Clio Knowledge Bundle Manifest v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contractVersion",
    "bundleSchemaVersion",
    "sequence",
    "bundleVersion",
    "issuedAt",
    "source",
    "compatibility",
    "requirements",
    "digestAlg",
    "signature",
    "resources"
  ],
  "properties": {
    "contractVersion": { "const": "0.1.0" },
    "bundleSchemaVersion": { "const": "0.1.0" },
    "sequence": { "type": "integer", "minimum": 1 },
    "bundleVersion": { "type": "string", "minLength": 1 },
    "issuedAt": { "type": "string", "format": "date-time" },
    "source": { "$ref": "#/$defs/source" },
    "compatibility": { "$ref": "#/$defs/compatibility" },
    "requirements": { "$ref": "#/$defs/requirements" },
    "digestAlg": { "const": "SHA-256" },
    "signature": { "$ref": "#/$defs/signature" },
    "resources": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/resource" }
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "commit"],
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "commit": { "type": "string", "pattern": "^[0-9a-fA-F]{7,64}$" }
      }
    },
    "versionRange": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min", "max"],
      "properties": {
        "min": { "type": "string", "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$" },
        "max": { "type": "string", "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$" }
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["clio", "mcpToolContract"],
      "properties": {
        "clio": { "$ref": "#/$defs/versionRange" },
        "mcpToolContract": { "$ref": "#/$defs/versionRange" }
      }
    },
    "requirements": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tools", "guidanceIds", "resourceUris"],
      "properties": {
        "tools": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "guidanceIds": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "resourceUris": { "type": "array", "items": { "type": "string", "pattern": "^docs://" }, "uniqueItems": true }
      }
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "keyId"],
      "properties": {
        "algorithm": { "const": "ECDSA-P256-SHA256" },
        "keyId": { "type": "string", "minLength": 1 }
      }
    },
    "resource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "uri", "path", "mediaType", "length", "digest"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "uri": { "type": "string", "pattern": "^docs://" },
        "path": { "type": "string", "pattern": "^resources/(?!.*\\.\\.)[^\\\\]+$" },
        "mediaType": { "type": "string", "minLength": 1 },
        "length": { "type": "integer", "minimum": 0 },
        "digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    }
  }
}
